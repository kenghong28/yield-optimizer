# HyperEVM Configuration
RPC_URL=https://rpc.hyperliquid.xyz/evm
WS_RPC_URL=wss://rpc.hyperliquid.xyz/evm
CHAIN_ID=999

# Database Configuration (Required)
# Replace with your actual Supabase/PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:port/database

# Redis Configuration
REDIS_URL=localhost:6379

# Contract Addresses (Required)
# Replace with actual contract addresses
POSITION_MANAGER_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
VAULT_ADDRESSES=0xabcdef1234567890abcdef1234567890abcdef12,0xfedcba0987654321fedcba0987654321fedcba09

# Oracle Configuration
ORACLE_PRECOMPILE=0x0000000000000000000000000000000000000807

# Performance Settings (Optional)
MAX_CONCURRENT_CHECKS=10
BATCH_SIZE=100
WORKER_COUNT=5
POSITION_CHECK_INTERVAL=30s
PRICE_UPDATE_INTERVAL=5s

# Logging
LOG_LEVEL=info

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090