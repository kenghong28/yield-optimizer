# HyperEVM Configuration
RPC_URL=https://rpc.hyperliquid.xyz/evm
WS_RPC_URL=wss://rpc.hyperliquid.xyz/evm
CHAIN_ID=999

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.projectid.supabase.co:5432/postgres
SUPABASE_URL=https://projectid.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Redis Configuration
REDIS_URL=localhost:6379

# Contract Addresses (Deploy and update these)
POSITION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VAULT_ADDRESSES=0x0000000000000000000000000000000000000000

# Oracle Configuration
ORACLE_PRECOMPILE=0x0000000000000000000000000000000000000807

# Private Keys (DO NOT COMMIT REAL KEYS)
REBALANCER_PRIVATE_KEY=your_rebalancer_private_key_here
ADMIN_PRIVATE_KEY=your_admin_private_key_here

# API Configuration
API_PORT=3000
WEBSOCKET_PORT=3001
ADMIN_PORT=3002
GATEWAY_PORT=8080

# Security
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3000

# Monitoring Configuration
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PORT=9090
POSITION_CHECK_INTERVAL=30s
PRICE_UPDATE_INTERVAL=5s
MAX_CONCURRENT_CHECKS=10
BLOCK_CONFIRMATIONS=2

# Performance Settings
BATCH_SIZE=100
WORKER_COUNT=5

# Strategy Parameters
DEFAULT_STRATEGY=volatility_adaptive
REBALANCE_THRESHOLD=0.8
MIN_REBALANCE_INTERVAL=3600
GAS_PRICE_MULTIPLIER=1.1

# MEV Protection
FLASHBOTS_ENDPOINT=https://relay.flashbots.net
PRIVATE_MEMPOOL_ENABLED=true

# Fees
PERFORMANCE_FEE_BPS=1000
MANAGEMENT_FEE_BPS=100

# Development
NODE_ENV=development
DEBUG=true